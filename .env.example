# OpenAI credentials
OPENAI_API_KEY=your_openai_api_key_here

# LLM and embedding models
LLM_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# RAGAnything config — all values are read directly by RAGAnythingConfig
WORKING_DIR=./rag_storage
OUTPUT_DIR=./output
PARSER=mineru
PARSE_METHOD=auto
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true

# MinerU backend: pipeline = lightweight, works without a GPU
# Other options: hybrid-auto-engine (needs GPU), vlm-auto-engine (needs GPU)
MINERU_BACKEND=pipeline
