# Docker image registry/mirror (China: docker.m.daocloud.io; elsewhere: docker.io)
REGISTRY=docker.m.daocloud.io

# Custom image names. Default = build/load locally. To pull prebuilt images from a registry,
# set these to your repos, e.g. APP_IMAGE=youruser/raganything-app:latest
# APP_IMAGE=raganything-app:latest
# DOTS_IMAGE=raganything-dotsocr:latest

# Qwen via DashScope (OpenAI-compatible). Endpoint must match your key's region.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-flash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
MAX_TOKENS=8192

# dots.ocr parser (vLLM, OpenAI-compatible). Compose overrides URL to the service name.
DOTS_OCR_URL=http://localhost:8000/v1
DOTS_OCR_MODEL=model
DOTS_DPI=200

# Paths
DOCUMENTS_DIR=./documents
WORKING_DIR=./rag_storage
OUTPUT_DIR=./output
DROP_MAX_CHARS=50
RAG_WORKSPACE=sketchup

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DATABASE=ragdb
POSTGRES_SSL_MODE=disable

# Qdrant
QDRANT_URL=http://localhost:6333

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ragpassword
